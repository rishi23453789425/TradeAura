# Environment Configuration

# ===== SERVER =====
NODE_ENV=development
PORT=5000

# ===== DATABASE =====
DATABASE_URL=postgresql://tradeaura:tradeaura_pass@localhost:5432/tradeaura
DB_HOST=localhost
DB_PORT=5432
DB_NAME=tradeaura
DB_USER=tradeaura
DB_PASSWORD=tradeaura_pass

# ===== CACHE =====
REDIS_URL=redis://localhost:6379
REDIS_HOST=localhost
REDIS_PORT=6379

# ===== JWT Authentication =====
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production
JWT_EXPIRE=30d
REFRESH_TOKEN_EXPIRE=90d

# ===== Frontend URLs =====
VITE_API_URL=http://localhost:5000
VITE_WS_URL=ws://localhost:5000
VITE_APP_NAME=TradeAura

# ===== Market Data APIs =====
ALPHAVANTAGE_KEY=demo
COINGECKO_API_KEY=
FINANCE_API_KEY=
YAHOO_FINANCE_KEY=

# ===== Payment Gateway (Razorpay) =====
RAZORPAY_KEY_ID=your_razorpay_key_id
RAZORPAY_KEY_SECRET=your_razorpay_key_secret

# ===== Email Service (SMTP) =====
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
SMTP_FROM_NAME=TradeAura
SMTP_FROM_EMAIL=noreply@tradeaura.com

# ===== AWS S3 (For file uploads) =====
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
AWS_S3_BUCKET=tradeaura-files

# ===== Logging =====
LOG_LEVEL=debug
LOG_FORMAT=combined

# ===== CORS =====
CORS_ORIGIN=http://localhost:3000
CORS_CREDENTIALS=true

# ===== Session =====
SESSION_SECRET=your_session_secret_key_here
